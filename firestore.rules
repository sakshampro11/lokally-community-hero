rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }
    match /issues/{issueId} {
      allow read, write: if true;
    }
    match /cached_insights/{insightId} {
      allow read, write: if true;
    }
  }
}
